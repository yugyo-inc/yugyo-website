# PocketBase instance URL（PocketHost.io 等で作成したインスタンスのルートURL）
# 未設定 or localhost の場合、news / members は空表示にフォールバックする。
NEXT_PUBLIC_PB_URL="https://YOUR-INSTANCE.pockethost.io"
NEXT_PUBLIC_SITE_URL="https://yugyo.work"

# --- Contact form (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"          # Resend のAPIキー
CONTACT_TO="info@yugyo.work"                      # 受信先
CONTACT_FROM="yugyo.work <noreply@yugyo.work>"    # 認証済みドメインの送信元（要 Resend ドメイン認証）
