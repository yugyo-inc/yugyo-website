[
  {
    "name": "news",
    "type": "base",
    "system": false,
    "listRule": "status = \"published\" && published_at <= @now",
    "viewRule": "status = \"published\" && published_at <= @now",
    "createRule": null,
    "updateRule": null,
    "deleteRule": null,
    "schema": [
      { "name": "title_jp", "type": "text", "required": true, "options": { "min": 1, "max": 120 } },
      { "name": "title_en", "type": "text", "required": false, "options": { "max": 120 } },
      { "name": "slug", "type": "text", "required": true, "options": { "min": 3, "max": 80, "pattern": "^[a-z0-9-]+$" } },
      { "name": "category", "type": "select", "required": true, "options": { "maxSelect": 1, "values": ["press", "event", "partnership", "award", "media"] } },
      { "name": "excerpt", "type": "text", "required": true, "options": { "max": 200 } },
      { "name": "body_jp", "type": "editor", "required": true, "options": {} },
      { "name": "body_en", "type": "editor", "required": false, "options": {} },
      { "name": "hero_image", "type": "file", "required": false, "options": { "maxSelect": 1, "maxSize": 5242880, "mimeTypes": ["image/jpeg", "image/png", "image/webp"] } },
      { "name": "external_url", "type": "url", "required": false, "options": {} },
      { "name": "published_at", "type": "date", "required": true, "options": {} },
      { "name": "status", "type": "select", "required": true, "options": { "maxSelect": 1, "values": ["draft", "published", "archived"] } },
      { "name": "tags", "type": "json", "required": false, "options": { "maxSize": 2000000 } }
    ],
    "indexes": [
      "CREATE UNIQUE INDEX `idx_news_slug` ON `news` (`slug`)"
    ]
  },
  {
    "name": "members",
    "type": "base",
    "system": false,
    "listRule": "is_public = true",
    "viewRule": "is_public = true",
    "createRule": null,
    "updateRule": null,
    "deleteRule": null,
    "schema": [
      { "name": "name_jp", "type": "text", "required": true, "options": { "max": 80 } },
      { "name": "name_en", "type": "text", "required": false, "options": { "max": 80 } },
      { "name": "role_jp", "type": "text", "required": true, "options": { "max": 80 } },
      { "name": "role_en", "type": "text", "required": false, "options": { "max": 80 } },
      { "name": "bio_jp", "type": "text", "required": false, "options": { "max": 400 } },
      { "name": "bio_en", "type": "text", "required": false, "options": { "max": 400 } },
      { "name": "photo", "type": "file", "required": false, "options": { "maxSelect": 1, "maxSize": 3145728, "mimeTypes": ["image/jpeg", "image/png", "image/webp"] } },
      { "name": "email", "type": "email", "required": false, "options": {} },
      { "name": "twitter_handle", "type": "text", "required": false, "options": { "max": 30 } },
      { "name": "linkedin_url", "type": "url", "required": false, "options": {} },
      { "name": "order", "type": "number", "required": true, "options": { "min": 0 } },
      { "name": "is_public", "type": "bool", "required": false, "options": {} }
    ],
    "indexes": []
  }
]
